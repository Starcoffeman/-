<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Жар-птица - Главное меню" Height="450" Width="800">

    <Window.Resources>
        <Style x:Key="MainButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="#2C3E50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3498DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Image Width="40" Height="40" Margin="0,0,10,0"/>
                    <TextBlock Text="Жар-птица" FontSize="24" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="UserInfoText" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button x:Name="AuthButton" Content="Войти" Width="80" Height="30" Click="AuthButton_Click" Background="#3498DB" Foreground="White"/>
                    <Button x:Name="LogoutButton" Content="Выйти" Width="80" Height="30" Click="LogoutButton_Click" Background="#E74C3C" Foreground="White" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основное содержимое -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <TextBlock Text="Добро пожаловать в аптеку &quot;Жар-птица&quot;" 
                           FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Качественные лекарства по доступным ценам" 
                           FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,30" 
                           Foreground="#7F8C8D"/>

                <Border Background="#ECF0F1" Padding="20" CornerRadius="10" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Навигация" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                        <WrapPanel HorizontalAlignment="Center">
                            <Button x:Name="ProductsButton" Content="Товары" Style="{StaticResource MainButtonStyle}" Click="ProductsButton_Click"/>
                            <Button x:Name="CartButton" Content=" Корзина" Style="{StaticResource MainButtonStyle}" Click="CartButton_Click" Visibility="Collapsed"/>
                            <Button x:Name="OrdersButton" Content="Заказы" Style="{StaticResource MainButtonStyle}" Click="OrdersButton_Click" Visibility="Collapsed"/>
                            <Button x:Name="AdminProductsButton" Content="Управление товарами" Style="{StaticResource MainButtonStyle}" Click="AdminProductsButton_Click" Visibility="Collapsed"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>


</Window>
