<Window x:Class="WpfApp1.ProductListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Товары - Жар-птица" 
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate x:Key="ProductTemplate">
            <Border Margin="10" Padding="10" CornerRadius="8" 
                    BorderBrush="#BDC3C7" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Фото -->
                    <Border Width="100" Height="100" Background="#F0F0F0" CornerRadius="5">
                        <Image Source="{Binding ImagePath}" 
                               Stretch="UniformToFill"
                               />
                    </Border>

                    <!-- Информация -->
                    <StackPanel Grid.Column="1" Margin="10,0">
                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ProductTypes.Name}" FontSize="12" Foreground="#7F8C8D"/>
                        <TextBlock Text="{Binding Composition}" FontSize="12" 
                                   TextWrapping="Wrap" MaxHeight="40"/>
                        <TextBlock Text="{Binding Description}" FontSize="11" 
                                   Foreground="#555" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Цена и кнопки -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Price, StringFormat={}{0:C}}" 
                                       FontSize="18" FontWeight="Bold" Foreground="#E74C3C"/>
                            <TextBlock Text="{Binding Discount, StringFormat=' -{0}%'}" 
                                       FontSize="12" Foreground="Green" Margin="5,0,0,0"/>
                        </StackPanel>

                        <Button x:Name="AddToCartButton" Content="В корзину" 
                                Height="30" Width="100" Margin="0,5,0,0"
                                Background="#27AE60" Foreground="White"
                                Click="AddToCartButton_Click"
                                Tag="{Binding Id}"/>

                        <Button x:Name="EditButton" Content="Редактировать" 
                                Height="30" Width="100" Margin="0,5,0,0"
                                Background="#3498DB" Foreground="White"
                                Click="EditButton_Click"
                                Tag="{Binding Id}"
                                />

                        <Button x:Name="DeleteButton" Content="Удалить" 
                                Height="30" Width="100" Margin="0,5,0,0"
                                Background="#E74C3C" Foreground="White"
                                Click="DeleteButton_Click"
                                Tag="{Binding Id}"
                                />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтрации и поиска -->
        <Border Grid.Row="0" Background="#ECF0F1" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <TextBox x:Name="SearchTextBox" Grid.Column="0" Height="35" 
                         FontSize="14" TextChanged="SearchTextBox_TextChanged"
                         Tag="Поиск по названию, составу, описанию..."/>

                <!-- Фильтр по типу -->
                <ComboBox x:Name="TypeFilterComboBox" Grid.Column="1" Width="200" 
                          Height="35" Margin="10,0" SelectionChanged="TypeFilterComboBox_SelectionChanged"/>

                <!-- Сортировка -->
                <ComboBox x:Name="SortComboBox" Grid.Column="2" Width="150" 
                          Height="35" SelectionChanged="SortComboBox_SelectionChanged">
                    <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                    <ComboBoxItem Content="Цена ↑"/>
                    <ComboBoxItem Content="Цена ↓"/>
                </ComboBox>
            </Grid>
        </Border>

        <!-- Список товаров -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ProductsItemsControl" ItemsSource="{Binding}" 
                          ItemTemplate="{StaticResource ProductTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- Кнопка добавления товара (только для админа) -->
        <Button x:Name="AddProductButton" Content="+ Добавить товар" 
                Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Width="150" Height="40" Margin="0,0,20,20"
                Background="#27AE60" Foreground="White" FontWeight="Bold"
                Click="AddProductButton_Click"
                Visibility="Collapsed"/>
    </Grid>
</Window>
