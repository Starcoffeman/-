<Window x:Class="WpfApp1.RegistorPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="RegistorPage" Height="450" Width="800">
    <Grid>
        <!-- Определяем колонки и строки -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="500"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <Grid Grid.Column="1" HorizontalAlignment="Center" Height="AUTO" Margin="0,100" VerticalAlignment="Center" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="177*"/>
                <ColumnDefinition Width="97*"/>
            </Grid.ColumnDefinitions>
            <TextBlock FontSize="20"
                   HorizontalAlignment="Center"  TextWrapping="Wrap" Text="Cтраница входа" VerticalAlignment="Top" Grid.ColumnSpan="2" />

            <TextBox x:Name="name" HorizontalAlignment="Left" Margin="0,60,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="200"  Grid.ColumnSpan="2"/>
            <TextBox x:Name="password" HorizontalAlignment="Left" Margin="0,100,0,0" Width="200" VerticalAlignment="Top" TextWrapping="Wrap" Grid.ColumnSpan="2" />
            <Button Grid.ColumnSpan="2" Margin="0,130,0,0" Padding="20,2" Content="Войти" HorizontalAlignment="Center"  VerticalAlignment="Bottom" />
            <Label x:Name="NoAccount" MouseDown="NoAccount_MouseDown" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="63,0,0,-26"  VerticalAlignment="Bottom" Content="Нет аккунта"  />
        </Grid>

    </Grid>
</Window>
