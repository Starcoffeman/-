<Window x:Class="WpfApp1.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Редактирование товара - Жар-птица" 
        Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Text="Добавление товара" FontSize="22" 
                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Изображение" FontSize="14" Margin="0,0,0,5"/>
                <Border Width="300" Height="200" Background="#F0F0F0" 
                        CornerRadius="5" Margin="0,0,0,10">
                    <Grid>
                        <Image x:Name="ProductImage" Stretch="UniformToFill"/>
                        <Button x:Name="SelectImageButton" Content="Выбрать изображение" 
                                Width="150" Height="30" VerticalAlignment="Bottom" 
                                HorizontalAlignment="Center" Margin="0,0,0,10"
                                Background="#3498DB" Foreground="White"
                                Click="SelectImageButton_Click"/>
                    </Grid>
                </Border>

                <TextBlock Text="Наименование*" FontSize="14" Margin="0,0,0,5"/>
                <TextBox x:Name="NameTextBox" Height="35" Margin="0,0,0,15" FontSize="14"/>

                <TextBlock Text="Тип продукции*" FontSize="14" Margin="0,0,0,5"/>
                <ComboBox x:Name="ProductTypeComboBox" Height="35" Margin="0,0,0,15" 
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Text="Стоимость*" FontSize="14" Margin="0,0,0,5"/>
                <TextBox x:Name="PriceTextBox" Height="35" Margin="0,0,0,15" FontSize="14"/>

                <TextBlock Text="Скидка (%)" FontSize="14" Margin="0,0,0,5"/>
                <TextBox x:Name="DiscountTextBox" Height="35" Margin="0,0,0,15" FontSize="14" Text="0"/>

                <TextBlock Text="Состав" FontSize="14" Margin="0,0,0,5"/>
                <TextBox x:Name="CompositionTextBox" Height="80" TextWrapping="Wrap" 
                         Margin="0,0,0,15" FontSize="14"/>

                <TextBlock Text="Описание" FontSize="14" Margin="0,0,0,5"/>
                <TextBox x:Name="DescriptionTextBox" Height="100" TextWrapping="Wrap" 
                         Margin="0,0,0,15" FontSize="14"/>

                <TextBlock Text="Минимальный остаток" FontSize="14" Margin="0,0,0,5"/>
                <TextBox x:Name="MinStockTextBox" Height="35" Margin="0,0,0,15" FontSize="14" Text="0"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="SaveButton" Content="Сохранить" Width="100" Height="35" 
                    Margin="0,0,10,0" Background="#27AE60" Foreground="White"
                    Click="SaveButton_Click"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="100" Height="35" 
                    Background="#95A5A6" Foreground="White" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
