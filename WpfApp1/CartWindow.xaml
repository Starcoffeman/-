<Window x:Class="WpfApp1.CartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Корзина - Жар-птица" 
        Height="500" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Моя корзина" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="CartItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5" Padding="10" CornerRadius="5" 
                                BorderBrush="#BDC3C7" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Image Source="{Binding Products.ImagePath}" Width="60" Height="60" 
                                       Stretch="UniformToFill" />

                                <StackPanel Grid.Column="1" Margin="10,0">
                                    <TextBlock Text="{Binding Products.Name}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding Products.ProductTypes.Name}" FontSize="11" Foreground="#7F8C8D"/>
                                    <TextBlock Text="{Binding Products.Price, StringFormat={}{0:C}}" 
                                               Foreground="#E74C3C" FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                    <Button Content="-" Width="30" Height="30" 
                                            Click="DecreaseQuantity_Click" Tag="{Binding Id}"/>
                                    <TextBlock Text="{Binding Quantity}" Width="40" TextAlignment="Center" 
                                               VerticalAlignment="Center" FontSize="14"/>
                                    <Button Content="+" Width="30" Height="30" 
                                            Click="IncreaseQuantity_Click" Tag="{Binding Id}"/>
                                </StackPanel>

                                <Button Grid.Column="3" Content="❌" Width="40" Height="40" 
                                        Background="Transparent" Foreground="Red"
                                        Click="RemoveFromCart_Click" Tag="{Binding Id}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#ECF0F1" Padding="10" Margin="0,10">
            <Grid>
                <TextBlock Text="Итого:" FontSize="18" FontWeight="Bold"/>
                <TextBlock x:Name="TotalAmountText" FontSize="18" FontWeight="Bold" 
                           Foreground="#E74C3C" HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Border Grid.Row="3" Padding="10" Margin="0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Адрес доставки:" FontSize="14" Margin="0,0,0,5"/>
                <TextBox x:Name="AddressTextBox" Grid.Row="1" Height="35" Width="400" 
                         FontSize="14" Tag="Введите адрес доставки"/>

                <StackPanel Grid.Column="1" Grid.RowSpan="2" Orientation="Horizontal" 
                            VerticalAlignment="Center" Margin="20,0,0,0">
                    <Button x:Name="OrderButton" Content="Оформить заказ" Width="150" Height="40" 
                            Background="#27AE60" Foreground="White" FontWeight="Bold"
                            Click="OrderButton_Click" Margin="0,0,10,0"/>
                    <Button x:Name="ClearCartButton" Content="Очистить корзину" Width="150" Height="40" 
                            Background="#E74C3C" Foreground="White"
                            Click="ClearCartButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
